{
  "name": "el-shafey-family-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "\"$npm_node_execpath\" node_modules/next/dist/bin/next dev",
    "dev:sites": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "\"$npm_node_execpath\" node_modules/next/dist/bin/next build",
    "build:netlify": "\"$npm_node_execpath\" \"$npm_execpath\" run build",
    "build:sites": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "\"$npm_node_execpath\" node_modules/next/dist/bin/next start",
    "start:sites": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "\"$npm_node_execpath\" \"$npm_execpath\" run build && \"$npm_node_execpath\" --test tests/*.test.mjs",
    "test:unit": "\"$npm_node_execpath\" --test tests/registry.test.mjs",
    "test:rendered": "\"$npm_node_execpath\" --test tests/rendered-html.test.mjs",
    "test:e2e": "\"$npm_node_execpath\" node_modules/@playwright/test/cli.js test",
    "lint": "\"$npm_node_execpath\" node_modules/eslint/bin/eslint.js . --max-warnings=0",
    "typecheck": "\"$npm_node_execpath\" node_modules/typescript/bin/tsc --noEmit --incremental false",
    "seo:check": "\"$npm_node_execpath\" scripts/seo-check.mjs",
    "preview:check": "\"$npm_node_execpath\" scripts/preview-check.mjs",
    "security:scan": "\"$npm_node_execpath\" scripts/security-scan.mjs",
    "verify": "\"$npm_node_execpath\" scripts/verify.mjs",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.11",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@cloudflare/vite-plugin": "1.37.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.11",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.3"
  },
  "type": "module"
}
